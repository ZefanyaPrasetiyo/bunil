generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  password  String
  no_spmb   String?
  nama      String?
  jurusan   Jurusan?
  role      Role
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  nilai     Nilai[]
  sessions  Session[]

  @@map("user")
}

model MataPelajaran {
  id    String  @id @default(uuid())
  nama  String

  nilai Nilai[]
}

model Nilai {
  id      String @id @default(uuid())

  userId  String
  mapelId String

  nilai   Float

  user User @relation(fields: [userId],references: [id],onDelete: Cascade)

  mapel MataPelajaran @relation(fields: [mapelId],references: [id],onDelete: Cascade)
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId String
  user User @relation(fields: [userId],references: [id],onDelete: Cascade)
  @@index([userId])
  @@map("session")
}

enum Jurusan {
  DKV
  RPL
  ANIMASI
  TKJ
  BC
  TE
}

enum Role {
  USER
  ADMIN
}

enum Kelamin {
  Laki
  Perempuan
}